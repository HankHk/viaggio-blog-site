# Password per l'accesso alla pagina admin (/admin).
# Impostala in produzione; in sviluppo puoi usare .env.local.
ADMIN_PASSWORD=asd

# Su Vercel: crea un Blob store nel progetto (Storage) e il token viene aggiunto
# automaticamente. Così l'admin può salvare i viaggi in automatico senza modificare il repo.
# In locale non serve: i viaggi si salvano in data/trips.json.
# BLOB_READ_WRITE_TOKEN=
